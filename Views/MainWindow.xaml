<Window
    x:Class="DevTrack.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:DevTrack.Views"
    mc:Ignorable="d">

    <Grid>
        <StackPanel>
            <ListView x:Name="ProjectListView" Height="300" Margin="10"/>
            <Button x:Name="addProjectButton" Click="OnAddProjectClick">Add Project</Button>
            <Button x:Name="editProjectButton" Click="OnEditProjectClick">Edit Project</Button>
            <Button x:Name="deleteProjectButton" Click="OnDeleteProjectClick">Delete Project</Button>
        </StackPanel>
    </Grid>
</Window>
